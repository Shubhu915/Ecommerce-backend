# Server Config
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/ecom-backend

# Authentication
JWT_ACCESS_SECRET=your_super_secret_access_key_123456
JWT_REFRESH_SECRET=your_super_secret_refresh_key_654321
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=your_secure_cookie_secret_998877

# Email Configuration (SMTP)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM="E-com Store <no-reply@ecom.com>"

# Frontend/Client URLs
FRONTEND_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3001

# Cloudinary (Media Hosting)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payment Gateway (Stripe Example)
PAYMENT_SECRET_KEY=sk_test_...
PAYMENT_PUBLIC_KEY=pk_test_...

# Security & Traffic
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# AI Configuration
AI_PROVIDER=openai
AI_API_KEY=sk-proj-...
AI_MODEL=gpt-4-turbo
SEARCH_RESULT_LIMIT=10

# Caching
REDIS_URL=redis://localhost:6379
